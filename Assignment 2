def main_linked_list():
    """
    Main function to demonstrate all linked list operations.
    """
    print("\n" + "="*70)
    print("UNIVERSITY HELPDESK TICKET QUEUE")
    print("="*70)
    
    # Create a new ticket queue
    queue = TicketQueue()
    
    # 1. Enqueue Tickets
    print("\n1. Enqueuing tickets...")
    queue.enqueue_ticket(101, "Alice Johnson", "Cannot login to student portal")
    queue.enqueue_ticket(102, "Bob Williams", "WiFi connection issues in library")
    queue.enqueue_ticket(103, "Charlie Brown", "Printer not working")
    queue.enqueue_ticket(104, "Diana Prince", "Software installation request")
    queue.enqueue_ticket(105, "Edward Davis", "Email configuration problem")
    queue.display_queue()
    
    # 2. Priority Insert
    print("\n2. Priority Insert - Inserting new ticket after ticket 103...")
    queue.priority_insert(103, 106, "Fiona Zhang", "Urgent: System crash during exam")
    queue.display_queue()
    
    # 3. Resolve Ticket
    print("\n3. Resolve Ticket - Removing ticket 102...")
    queue.resolve_ticket(102)
    queue.display_queue()
    
    # 4. Find Middle Ticket
    print("\n4. Find Middle Ticket...")
    middle = queue.find_middle_ticket()
    if middle:
        print(f"   Middle ticket: ID {middle.ticket_id} | "
              f"Student: {middle.student_name} | Issue: {middle.issue}")
    
    # 5. Reverse Queue
    print("\n5. Reverse Queue...")
    queue.reverse_queue()
    print("   Queue reversed successfully!")
    queue.display_queue()
    
    # 6. Complexity Analysis
    print("\n6. Complexity Analysis:")
    complexities = complexitity_analysis_linked_list()
    for op_name, analysis in complexities.items():
        print(f"   {op_name}:")
        print(f"     Time: {analysis['time']}")
        print(f"     Explanation: {analysis['explanation']}")


if __name__ == "__main__":
    main_linked_list()



class Ticket:
    """
    Represents a single ticket node in the linked list.
    """
    def __init__(self, ticket_id, student_name, issue):
        """
        Initialize a ticket with ID, student name, and issue description.
        
        Args:
            ticket_id (int): Unique identifier for the ticket
            student_name (str): Name of the student
            issue (str): Description of the issue
        """
        self.ticket_id = ticket_id
        self.student_name = student_name
        self.issue = issue
        self.next = None


class TicketQueue:
    """
    Singly linked list implementation for ticket management.
    Supports enqueue, priority insert, resolve, find middle, reverse, and display.
    """
    
    def __init__(self):
        """Initialize an empty ticket queue."""
        self.head = None
        self._size = 0
    
    def enqueue_ticket(self, ticket_id, student_name, issue):
        """
        Add a new ticket to the end of the queue.
        
        Time Complexity: O(n) - Traverse to the end of the list
        
        Args:
            ticket_id (int): Unique ticket identifier
            student_name (str): Name of the student
            issue (str): Issue description
            
        Returns:
            bool: True if successful
        """
        new_ticket = Ticket(ticket_id, student_name, issue)
        
        if self.head is None:
            self.head = new_ticket
        else:
            current = self.head
            while current.next is not None:
                current = current.next
            current.next = new_ticket
        
        self._size += 1
        return True
    
    def priority_insert(self, target_ticket_id, ticket_id, student_name, issue):
        """
        Insert a new ticket immediately after the specified ticket ID.
        
        Time Complexity: O(n) - Search for the target position
        
        Args:
            target_ticket_id (int): ID of the ticket after which to insert
            ticket_id (int): ID of the new ticket
            student_name (str): Name of the student
            issue (str): Issue description
            
        Returns:
            bool: True if successful, False if target not found
        """
        if self.head is None:
            return False
        
        current = self.head
        
        # Find the target ticket
        while current is not None:
            if current.ticket_id == target_ticket_id:
                new_ticket = Ticket(ticket_id, student_name, issue)
                new_ticket.next = current.next
                current.next = new_ticket
                self._size += 1
                return True
            current = current.next
        
        return False
    
    def resolve_ticket(self, ticket_id):
        """
        Delete a ticket from the queue given its ID.
        
        Time Complexity: O(n) - Search for the ticket to delete
        
        Args:
            ticket_id (int): ID of the ticket to delete
            
        Returns:
            bool: True if successful, False if ticket not found
        """
        if self.head is None:
            return False
        
        # If the ticket to delete is the head
        if self.head.ticket_id == ticket_id:
            self.head = self.head.next
            self._size -= 1
            return True
        
        # Search for the ticket in the rest of the list
        current = self.head
        while current.next is not None:
            if current.next.ticket_id == ticket_id:
                current.next = current.next.next
                self._size -= 1
                return True
            current = current.next
        
        return False
    
    def find_middle_ticket(self):
        """
        Find the middle ticket of the queue in a single traversal pass.
        
        Time Complexity: O(n) - Single pass using fast/slow pointer
        
        Returns:
            Ticket: The middle ticket, or None if queue is empty
        """
        if self.head is None:
            return None
        
        slow = self.head
        fast = self.head
        
        # Move fast by 2 and slow by 1
        while fast is not None and fast.next is not None:
            slow = slow.next
            fast = fast.next.next
        
        return slow
    
    def reverse_queue(self):
        """
        Reverse the queue in-place by manipulating pointers without copying data.
        
        Time Complexity: O(n) - Single pass through the list
        
        Returns:
            bool: True if successful
        """
        if self.head is None or self.head.next is None:
            return True
        
        prev = None
        current = self.head
        
        while current is not None:
            next_temp = current.next
            current.next = prev
            prev = current
            current = next_temp
        
        self.head = prev
        return True
    
    def display_queue(self):
        """
        Print all ticket IDs and details in the queue.
        
        Time Complexity: O(n) - Traverse the entire list
        
        Returns:
            list: List of ticket dictionaries for display
        """
        if self.head is None:
            print("Queue is empty")
            return []
        
        tickets = []
        current = self.head
        position = 1
        
        print("\n" + "="*70)
        print("TICKET QUEUE")
        print("="*70)
        
        while current is not None:
            ticket_info = {
                'position': position,
                'ticket_id': current.ticket_id,
                'student_name': current.student_name,
                'issue': current.issue
            }
            tickets.append(ticket_info)
            
            print(f"#{position} | ID: {current.ticket_id} | "
                  f"Student: {current.student_name} | Issue: {current.issue}")
            
            current = current.next
            position += 1
        
        print("="*70)
        print(f"Total tickets: {self._size}")
        print("="*70)
        
        return tickets
    
    def get_size(self):
        """
        Get the number of tickets in the queue.
        
        Returns:
            int: Number of tickets
        """
        return self._size
    
    def is_empty(self):
        """
        Check if the queue is empty.
        
        Returns:
            bool: True if empty, False otherwise
        """
        return self.head is None



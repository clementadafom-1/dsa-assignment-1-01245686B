def most_frequent_registrant(registrations):
    """
    Find the student ID that appears the most times in the registration list.
    
    Time Complexity: O(n) - Single pass through the list
    Space Complexity: O(n) - Hash map stores at most n unique entries
    
    Args:
        registrations (list): List of student IDs
        
    Returns:
        int: The most frequent student ID, or None if list is empty
    """
    if not registrations:
        return None
    
    frequency = {}
    max_count = 0
    most_frequent = None
    
    for student_id in registrations:
        frequency[student_id] = frequency.get(student_id, 0) + 1
        if frequency[student_id] > max_count:
            max_count = frequency[student_id]
            most_frequent = student_id
    
    return most_frequent


def ordered_deduplication(registrations):
    """
    Remove all duplicate student IDs while preserving the order of first appearance.
    
    Time Complexity: O(n) - Single pass through the list
    Space Complexity: O(n) - Hash map to track seen elements
    
    Args:
        registrations (list): List of student IDs
        
    Returns:
        list: List with duplicates removed, preserving original order
    """
    if not registrations:
        return []
    
    seen = set()
    result = []
    
    for student_id in registrations:
        if student_id not in seen:
            seen.add(student_id)
            result.append(student_id)
    
    return result


def first_unique_student(registrations):
    """
    Find the first student ID that appears exactly once.
    
    Time Complexity: O(n) - Two passes through the list
    Space Complexity: O(n) - Hash map stores frequency counts
    
    Args:
        registrations (list): List of student IDs
        
    Returns:
        int: The first non-repeated student ID, or None if none exists
    """
    if not registrations:
        return None
    
    frequency = {}
    
    # First pass: Count occurrences
    for student_id in registrations:
        frequency[student_id] = frequency.get(student_id, 0) + 1
    
    # Second pass: Find first with count == 1
    for student_id in registrations:
        if frequency[student_id] == 1:
            return student_id
    
    return None


def contiguous_subarray_sum(registrations, target):
    """
    Determine if there exists a contiguous subarray whose sum equals the target.
    
    Time Complexity: O(n) - Using sliding window technique
    Space Complexity: O(1) - Only constant extra space
    
    For arrays with positive numbers, uses sliding window.
    For arrays with negative numbers, uses prefix sum with hash set.
    
    Args:
        registrations (list): List of integers
        target (int): Target sum to find
        
    Returns:
        bool: True if a contiguous subarray with sum equals target exists
    """
    if not registrations:
        return target == 0
    
    # Using sliding window for positive numbers
    # For general case with negatives, use prefix sum approach
    
    # Prefix sum approach (works for all integers)
    prefix_sum = 0
    seen_sums = set()
    
    for num in registrations:
        prefix_sum += num
        
        if prefix_sum == target:
            return True
        
        if (prefix_sum - target) in seen_sums:
            return True
        
        seen_sums.add(prefix_sum)
    
    return False


